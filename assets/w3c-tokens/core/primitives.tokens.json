{
  "$description": "Primitive tokens — raw, context-free values. Never reference these directly from components; reference them via the semantic layer.",
  "color": {
    "neutral": {
      "0":    { "$type": "color", "$value": "#FFFFFF" },
      "50":   { "$type": "color", "$value": "#F7F8FA" },
      "100":  { "$type": "color", "$value": "#EEF0F4" },
      "200":  { "$type": "color", "$value": "#D9DDE5" },
      "300":  { "$type": "color", "$value": "#BAC1CD" },
